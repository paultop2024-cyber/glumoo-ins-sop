# Glumoo INS portable env example

# Core paths
GLUMOO_WORKSPACE=/Users/Apple/.openclaw/workspace-ins
GLUMOO_MIRROR_ROOT=/Users/Apple/Documents/Glumoo/02_每日内容生成
# Optional overrides
# GLUMOO_SEND_ROOT=/Users/Apple/.openclaw/workspace/out/ins_daily
# GLUMOO_REF_DIR=/Users/Apple/.openclaw/workspace-ins/skills/glumoo-ins/assets/product_refs
# GLUMOO_NANO_BANANA=/opt/homebrew/lib/node_modules/openclaw/skills/nano-banana-pro/scripts/generate_image.py

# Yunwu text config (reserved for caption/copy flows and future upgrades)
XHS_TEXT_API_KEY=REPLACE_WITH_YOUR_YUNWU_TEXT_KEY
XHS_TEXT_BASE_URL=https://yunwu.ai
XHS_TEXT_MODEL=models/gemini-3.1-flash-lite-preview

# Yunwu image config (used by current image generation flow)
XHS_IMAGE_API_KEY=REPLACE_WITH_YOUR_YUNWU_IMAGE_KEY
XHS_IMAGE_BASE_URL=https://yunwu.ai
XHS_IMAGE_MODEL=gemini-3.1-flash-image-preview
XHS_IMAGE_ASPECT_RATIO=4:5

# Optional fallback for official Gemini
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_BASE_URL=
# GEMINI_MODEL=
